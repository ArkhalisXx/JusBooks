# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development        # change to 'production' on deployment

# ── JWT Access Token ──────────────────────────────────────────────────────────
# Used to sign short-lived access tokens (8h default).
# Must be a long random string — never commit the real value.
JWT_SECRET=replace_with_a_long_random_string_minimum_32_characters
JWT_EXPIRES_IN=8h

# ── JWT Refresh Token ─────────────────────────────────────────────────────────
# Must be DIFFERENT from JWT_SECRET.
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string_minimum_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12       # increase = more secure but slower; 12 is the standard

# ── Rate Limiting (Auth endpoints) ───────────────────────────────────────────
AUTH_RATE_LIMIT_MAX=10      # max login/register attempts per 15 minutes per IP

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173   # your frontend dev URL
