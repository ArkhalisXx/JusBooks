# JusBooks Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Change this to any long random string in production
JWT_SECRET=jusbooks_super_secret_change_this_in_production
JWT_EXPIRES_IN=8h

# ── Gmail OAuth2 (for email notifications) ────────────────────────────────────
# Guide: https://developers.google.com/gmail/api/auth/about-auth
# Step 1: Go to https://console.cloud.google.com
# Step 2: Create a project → Enable Gmail API
# Step 3: Create OAuth2 credentials (Desktop app)
# Step 4: Use OAuth2 Playground to get refresh token
GMAIL_USER=chriss.katigbak@gmail.com
